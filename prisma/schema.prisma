// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. USUÁRIOS (Gestores/Fábricas)
// ==========================================
model User {
  id                    String                 @id @default(uuid()) @db.Uuid
  name                  String?
  email                 String                 @unique
  cnpj                  String?                @unique
  phone                 String?
  password              String
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  // Relacionamentos Multi-Tenant
  clients               Client[]
  products              Product[]
  orders                Order[]
  financialTransactions FinancialTransaction[]
  companySettings       CompanySettings?

  @@map("users")
}

// ==========================================
// 2. CLIENTES (Compradores da Cartela B2B)
// ==========================================
enum ClientStatus {
  ACTIVE
  INACTIVE
}

model Client {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid @map("user_id")
  name      String
  cnpj      String?
  phone     String?
  email     String?
  status    ClientStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("clients")
}

// ==========================================
// 3. PRODUTOS (Catálogo do Usuário)
// ==========================================
model Product {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @db.Uuid @map("user_id")
  name       String
  price      Decimal     @db.Decimal(10, 2)
  stock      Int         @default(0)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("products")
}

// ===================================================
// 4. PEDIDOS (Registros de Vendas e Saídas)
// ===================================================
enum OrderStatus {
  PENDING   // Em andamento
  DELIVERED // Concluído (Gera baixa no estoque)
  CANCELED  // Cancelado
}

model Order {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @db.Uuid @map("user_id")
  clientId  String      @db.Uuid @map("client_id")
  total     Decimal     @db.Decimal(10, 2)
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items  OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid()) @db.Uuid
  orderId   String  @db.Uuid @map("order_id")
  productId String  @db.Uuid @map("product_id")
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ===================================================
// 5. CONFIGURAÇÕES DA EMPRESA
// ===================================================
model CompanySettings {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @db.Uuid @map("user_id")
  companyName String   @map("company_name")
  tradeName   String   @map("trade_name")
  cnpj        String
  phone       String?
  email       String?
  address     String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

// ===================================================
// 6. FINANÇAS
// ===================================================
enum TransactionType {
  INCOME  // Entrada
  EXPENSE // Saída
}

enum TransactionCategory {
  SALE        // Vendas (Entrada)
  TAX         // Impostos
  SALARY      // Salários
  SUPPLIES    // Insumos / Matéria-prima
  MAINTENANCE // Manutenção / Infraestrutura
  OTHER       // Outros
}

model FinancialTransaction {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @db.Uuid @map("user_id")
  description String
  amount      Decimal             @db.Decimal(10, 2)
  type        TransactionType
  category    TransactionCategory
  date        DateTime            @default(now())
  createdAt   DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("financial_transactions")
}